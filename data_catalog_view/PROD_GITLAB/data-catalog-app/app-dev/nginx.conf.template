# nginx.conf.template
# The ${API_BACKEND_URL} placeholder is replaced at container startup by
# docker-entrypoint.sh using envsubst. Set the Cloud Run env var
# API_BACKEND_URL to your API service URL, e.g.:
#   https://data-catalog-api-xxxx-ew.a.run.app

log_format debug_proxy '[$time_local] "$request" status=$status '
                       'Upstream: $upstream_addr '
                       'Incoming_Auth: "$http_authorization"';

server {
    listen 8080;
    server_name _;

    access_log /dev/stdout debug_proxy;

    # Serve pre-built Vite static files
    root /usr/share/nginx/html;
    index index.html;

    # ---------------------------------------------------------------
    # SPA catch-all: any non-file path is handed to React Router
    # ---------------------------------------------------------------
    location / {
        try_files $uri $uri/ /index.html;
    }

    # ---------------------------------------------------------------
    # Proxy /api/* → FastAPI backend on Cloud Run
    # ---------------------------------------------------------------

    location /api/ {
        
        include /tmp/auth_token.conf;

        proxy_pass          ${API_BACKEND_URL};
        proxy_http_version  1.1;
        
        proxy_set_header    Authorization "Bearer $api_id_token";

        proxy_set_header    Host              $proxy_host;
        proxy_set_header    X-Real-IP         $remote_addr;
        proxy_set_header    X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header    X-Forwarded-Proto $scheme;

        proxy_read_timeout  60s;
        proxy_send_timeout  60s;
    }

    # ---------------------------------------------------------------
    # Static asset caching (Vite hashes filenames on build)
    # ---------------------------------------------------------------
    location ~* \.(js|css|png|jpg|jpeg|gif|svg|ico|woff2?|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
        try_files $uri =404;
    }

    # Health check endpoint used by Cloud Run
    location /healthz {
        access_log off;
        return 200 "ok\n";
        add_header Content-Type text/plain;
    }
}
