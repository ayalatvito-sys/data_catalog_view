# Dependencies (never ship these)
**/node_modules/

# Build outputs (rebuilt inside Docker)
**/dist/
**/.tsbuildinfo

# Dev/local env
.env
.env.*
!.env.example

# IDE / editor
.vscode/
.idea/
*.swp

# Replit-specific
.replit
**/.replit-artifact/

# Git
.git/
.gitignore

# Docs / scripts not needed for build
*.md
_deployment/
